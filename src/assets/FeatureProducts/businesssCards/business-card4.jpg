 }
 .nbo-group-toggle {
 position: absolute;
 right: 10px;
 bottom: -14px;
 box-sizing: border-box;
 width: 28px;
 height: 28px;
 border: 2px solid #f8f8f8;
 border-radius: 50%;
 background: #fff;
 cursor: pointer;
 text-align: center;
 line-height: 24px;
 }
 .nbo-group-toggle svg{
 -webkit-transition: all 0.4s;
 -moz-transition: all 0.4s;
 transition: all 0.4s;
 transform: rotate(-180deg);
 }

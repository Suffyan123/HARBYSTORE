//                                        }
 factor += $scope.validate_float( soption_price[quantity_break.index] );
 }
 }
 }
 }
 }
 if( $scope.isMultipleSelectPage( origin_field ) ){
 factor = [];
 angular.forEach(field.values, function(val, v_index){

 color: #404762;
 display: inline-block;
 position: relative;
 padding: 0 15px;
 height: 40px;
 line-height: 40px;
 box-sizing: border-box;
 border-top-left-radius: 4px;
 font-weight: bold;
 max-width: calc(100% - 50px);
 }
 .nbo-group-header .group-title:after {

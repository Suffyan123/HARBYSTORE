 }
 .nbd-option-field.nbo-collapse .nbd-field-header .nbo-plus {
 display: unset;
 }
 .nbd-option-field .nbd-field-content {
 -webkit-transition: all 0.4s;
 -moz-transition: all 0.4s;
 transition: all 0.4s;
 }
 .nbd-option-field.nbo-collapse .nbd-field-content {
